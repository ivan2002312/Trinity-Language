module Test;
class Main {
    static int main() {
        var x = 10;
        var y = 20;
        var sum = x + y;
        println("Sum: ", sum);
        if (sum > 20) {
            println("Greater than 20!");
        }
        for (var i = 0; i < 5; i = i + 1) {
            println("Loop: ", i);
        }
        return sum;
    }
}
