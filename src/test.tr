module Multiplication;

static int main() {
    println("Таблица умножения 10x10:");
    println("");
    
    // Заголовок
    print("     ");
    for (var i = 1; i <= 10; i = i + 1) {
        if (i < 10) {
            print("  ", i, " ");
        } else {
            print(" ", i, " ");
        }
    }
    println("");
    
    // Разделитель
    print("     ");
    for (var i = 1; i <= 10; i = i + 1) {
        print("----");
    }
    println("");
    
    // Таблица
    for (var row = 1; row <= 10; row = row + 1) {
        if (row < 10) {
            print(" ", row, " |");
        } else {
            print(row, " |");
        }
        
        for (var col = 1; col <= 10; col = col + 1) {
            var result = row * col;
            if (result < 10) {
                print("  ", result, " ");
            } else if (result < 100) {
                print(" ", result, " ");
            } else {
                print(result, " ");
            }
        }
        println("");
    }
    
    return 0;
}